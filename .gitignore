# Secrets — never commit these
.env
*.env.local

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/

# SQLite persistence written by the graph (anywhere in the repo,
# not just sqlite-data/, so a stale process with the old path cannot
# silently leave an untracked stub file at the repo root).
*.sqlite
*.sqlite-shm
*.sqlite-wal

# OS / editor
.DS_Store
.idea/
.vscode/
