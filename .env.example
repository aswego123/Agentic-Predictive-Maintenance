# Copy to `.env` and fill in real values. DO NOT commit `.env`.
#
# LLM provider — one of: none | anthropic | openai | azure | azure_apim
EIX_LLM_PROVIDER=azure_apim
EIX_LLM_MODEL=gpt-5-codex
EIX_LLM_TEMPERATURE=0.1

# Azure / APIM settings (required when provider = azure or azure_apim)
EIX_AZURE_ENDPOINT=https://<your-apim>.azure-api.net
EIX_AZURE_API_KEY=<put-real-key-here>
EIX_AZURE_API_VERSION=2024-06-01
EIX_AZURE_DEPLOYMENT=gpt-5-codex
